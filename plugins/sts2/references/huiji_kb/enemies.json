    "JAW_WORM": {
      "id": "JAW_WORM",
      "wiki_title": "颚虫",
      "name_zh": "颚虫",
      "name_en": "Jaw Worm",
      "tier": "normal",
      "acts": [1],
      "hp_solo": "40-44",
      "tags": ["strength_scaling", "act1"],
      "intents": [
        {"name": "咆哮", "type": "buff", "effect": "+2力量", "notes": "下回合咬/猛击伤害提高"},
        {"name": "咬", "type": "attack", "damage": 11},
        {"name": "猛击", "type": "attack", "damage": 12}
      ],
      "pattern": "循环：咆哮→咬→猛击→重复",
      "combat_plan": "看到咆哮：能击杀就全力输出；不能杀则格挡≥下回合预估伤害。勿空能量拖回合养力量。",
      "rule": "颚虫咆哮+2力：咆哮回合优先收尾或叠防，勿裸脸吃咬。"
    },
    "LOUSE": {
      "id": "LOUSE",
      "wiki_title": "虱子",
      "name_zh": "虱子",
      "tier": "normal",
      "acts": [1],
      "hp_solo": "10-14",
      "tags": ["curl", "act1"],
      "intents": [
        {"name": "蜷缩", "type": "block", "effect": "+7格挡"},
        {"name": "噬咬", "type": "attack", "damage": 6}
      ],
      "pattern": "蜷缩后下回合高伤噬咬；破防用多段或易伤",
      "combat_plan": "蜷缩回合：要么打破格挡打出伤害，要么自己叠防。两只虱子先杀会咬的那只。",
      "rule": "虱子蜷缩+7防：勿用单段小牌浪费，集中破防或留防吃咬。"
    },
    "ACID_LOUSE": {
      "id": "ACID_LOUSE",
      "name_zh": "酸液虱",
      "tier": "normal",
      "acts": [1],
      "hp_solo": "12-16",
      "tags": ["debuff", "curl"],
      "intents": [
        {"name": "蜷缩", "type": "block"},
        {"name": "酸液喷吐", "type": "attack", "damage": 6, "notes": "可能施加虚弱/易伤类减益"}
      ],
      "combat_plan": "同虱子；注意减益后调整下回合攻防。",
      "rule": "酸液虱：蜷缩破防；有虚弱时本回合伤害打折，先杀或先防。"
    },
    "SLIME": {
      "id": "SLIME",
      "name_zh": "史莱姆",
      "aliases": ["小史莱姆"],
      "tier": "normal",
      "acts": [1],
      "hp_solo": "12-18",
      "tags": ["split", "act1"],
      "intents": [
        {"name": "撞击", "type": "attack", "damage": 8},
        {"name": "分裂", "type": "other", "notes": "低血分裂为更小个体"}
